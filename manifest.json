{
  "manifest_version": 3,
  "name": "DataLemur Sync",
  "version": "1.0.0",
  "description": "Automatically sync your accepted DataLemur SQL solutions to a GitHub repository. No backend required.",
  "minimum_chrome_version": "116",
  "permissions": ["storage", "notifications"],
  "host_permissions": ["https://datalemur.com/*", "https://api.github.com/*"],
  "background": {
    "service_worker": "src/background/background.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://datalemur.com/*"],
      "js": ["src/content/content.ts"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "DataLemur Sync",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "32": "assets/icons/icon32.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  },
  "options_page": "src/options/options.html",
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  }
}
